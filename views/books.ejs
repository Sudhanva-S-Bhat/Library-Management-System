<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Books Management</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="sidebar">
        <h2>Library</h2>
        <a href="/dashboard">Dashboard</a>
        <a href="/books">Books</a>
        <a href="/borrowed-books">Borrowed Books</a>
        <a href="/students">Students</a>
        <a href="/library-visits">Library Visits</a>
        <a href="/logout">Logout</a>
    </div>
    <div class="main-page">
        <h1>Books Management</h1>
        <form action="/books" method="GET" class="search-form">
            <input type="text" name="search" placeholder="Search by title or author" value="<%= search || '' %>">
            <button type="submit">Search</button>
        </form>
        <a href="/books/add">Add New Book</a>
        <table>
            <tr>
                <th>Book Id</th>
                <th>Title</th>
                <th>Author</th>
                <th>Quantity</th>
                <th>Actions</th>
            </tr>
            <% books.forEach(book => { %>
                <tr>
                    <td><%= book.id %></td>
                    <td><%= book.title %></td>
                    <td><%= book.author %></td>
                    <td><%= book.quantity %></td>
                    <td>
                        <a href="/books/edit/<%= book.id %>">Edit</a>
                        <a href="/books/delete/<%= book.id %>">Delete</a>
                    </td>
                </tr>
            <% }) %>
        </table>
    </div>
</body>
</html>