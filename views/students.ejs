<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Students Management</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="sidebar">
        <h2>Library</h2>
        <a href="/dashboard">Dashboard</a>
        <a href="/books">Books</a>
        <a href="/borrowed-books">Borrowed Books</a>
        <a href="/students">Students</a>
        <a href="/library-visits">Library Visits</a>
        <a href="/logout">Logout</a>
    </div>
    <div class="main-page">
        <h1>Students Management</h1>
        <form action="/students" method="GET" class="search-form">
            <input type="text" name="search" placeholder="Search by USN or Name" value="<%= search || '' %>">
            <button type="submit">
                Search
            </button>
        </form>
        <a href="/students/add">Register New Student</a>
        <table>
            <tr>
                <th>USN</th>
                <th>Name</th>
                <th>Branch</th>
                <th>Actions</th>
            </tr>
            <% students.forEach(student => { %>
                <tr>
                    <td><%= student.usn %></td>
                    <td><%= student.name %></td>
                    <td><%= student.branch %></td>
                    <td>
                        <a href="/students/edit/<%= student.usn %>">Edit</a>
                        <a href="/students/delete/<%= student.usn %>">Delete</a>
                    </td>
                </tr>
            <% }) %>
        </table>
    </div>
</body>
</html>