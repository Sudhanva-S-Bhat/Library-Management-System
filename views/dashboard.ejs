<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="sidebar">
        <h2>Library</h2>
        <a href="/dashboard">Dashboard</a>
        <a href="/books">Books</a>
        <a href="/borrowed-books">Borrowed Books</a>
        <a href="/students">Students</a>   
        <a href="/library-visits">Library Visits</a> 
        <a href="/logout">Logout</a>
    </div>
    <div class="main">
        <h1>Welcome <%= librarian.name %></h1>
        <div class="cards">
            <div class="card">
                <h2><%= totalBooks %></h2>
                <p>Total Books</p>
            </div>
            <div class="card">
                <h2><%= totalBorrowed %></h2>
                <p>Total Borrowed</p>
            </div>
            <div class="card">
                <h2><%= totalVisits %></h2>
                <p>Total Visitors</p>
            </div>
        </div>
    </div>
</body>
</html>