<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Book</title>
     <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="sidebar">
        <h2>Library</h2>
        <a href="/dashboard">Dashboard</a>
        <a href="/books">Books</a>
        <a href="/borrowed-books">Borrowed Books</a>
        <a href="/students">Students</a>
        <a href="/library-visits">Library Visits</a>
        <a href="/logout">Logout</a>
    </div>
    <div class="edit-form">
        <form action="/books/edit/<%= book.id %>" method="POST">
            <input type="text" name="id" value="<%= book.id %>" disabled>
            <input type="text" name="title" value="<%= book.title %>">
            <input type="text" name="author" value="<%= book.author %>">
            <input type="text" name="quantity" value="<%= book.quantity %>">
            <button>Edit Book</button>
        </form>
    </div>
</body>
</html>