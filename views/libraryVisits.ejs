<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Library Visits</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="sidebar">
        <h2>Library</h2>
        <a href="/dashboard">Dashboard</a>
        <a href="/books">Books</a>
        <a href="/borrowed-books">Borrowed Books</a>
        <a href="/students">Students</a>
        <a href="/library-visits">Library Visits</a>
        <a href="/logout">Logout</a>
    </div>
    <div class="main-page">
        <h1>Library Visits</h1>
        <a href="/library-visits/add">Mark IN / OUT</a>
        <table>
            <tr>
                <th>Visit ID</th>
                <th>USN</th>
                <th>Student Name</th>
                <th>IN Time</th>
                <th>OUT Time</th>
                <th>Duration</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
            <% visits.forEach(visit=>{ %>
                <tr>
                    <td><%= visit.id %></td>
                    <td><%= visit.usn %></td>
                    <td><%= visit.name %></td>
                    <td><%= new Date(visit.entry_time).toLocaleString() %></td>
                    <td><% if(visit.exit_time){ %>
                            <%= new Date(visit.exit_time).toLocaleString() %>
                        <% } else { %>
                            --
                        <% } %>
                    </td>
                    <td><%= visit.duration || "--" %></td>
                    <td><% if(visit.exit_time){ %>
                            OUT
                        <% } else { %>
                            INSIDE
                        <% } %>
                    </td>
                    <td><a href="/library-visits/delete/<%= visit.id %>">Remove</a></td>
                </tr>
            <% }) %>
        </table>
    </div>
</body>
</html>