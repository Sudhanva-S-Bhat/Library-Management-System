<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Library In / Out</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="sidebar">
        <h2>Library</h2>
        <a href="/dashboard">Dashboard</a>
        <a href="/books">Books</a>
        <a href="/borrowed-books">Borrowed Books</a>
        <a href="/students">Students</a>
        <a href="/library-visits">Library Visits</a>
        <a href="/logout">Logout</a>
    </div>
    <div class="form-box">
        <div class="total-in-card">
            <h3>Total Students Inside</h3>
            <h1><%= totalIn %></h1>
        </div>
        <form action="/library-visits/add" method="POST">
            <h1>Library Entry / Exit</h1>
            <input type="text" name="usn" placeholder="Enter Student USN" autocomplete="off" required>
            <button>Mark Attendance</button>
        </form>
        <% if(result){ %>
            <div class="visit-result" id="visitResult">
                <% if(result.error){ %>
                    <h3 class="error">
                        <%= result.error %>
                    </h3>
                <% } else { %>
                    <h2>Attendance Recorded</h2>
                    <p>
                        <strong>Name:</strong>
                        <%= result.name %>
                    </p>
                    <p>
                        <strong>USN:</strong>
                        <%= result.usn %>
                    </p>
                    <p>
                        <strong>Status:</strong>
                        <%= result.status %>
                    </p>
                    <% if(result.status==="IN"){ %>
                        <p>
                            <strong>IN Time:</strong>
                            <%= result.inTime %>
                        </p>
                    <% } else { %>
                        <p>
                            <strong>OUT Time:</strong>
                            <%= result.outTime %>
                        </p>
                        <p>
                            <strong>Duration:</strong>
                            <%= result.duration %>
                        </p>
                    <% } %>
                <% } %>
            </div>
        <% } %>
    </div>
    <script>
    setTimeout(() => {
        const result = document.getElementById('visitResult');
        if(result){
            result.style.opacity = "0";
            setTimeout(() => {
                result.remove();
            }, 500);
        }
    }, 3000);
    </script>
</body>
</html>